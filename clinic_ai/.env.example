# ============================================================
# ClinicOS — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ── App ─────────────────────────────────────────────────────
APP_NAME=ClinicOS
DEBUG=false
SESSION_SECRET=change-me-to-a-random-string
BASE_URL=http://localhost:8000
ALLOW_DEV_AUTH=true

# ── Database (Supabase PostgreSQL) ──────────────────────────
SUPABASE_DB_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── Auth0 ───────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_CALLBACK_URL=http://localhost:8000/auth/callback
AUTH0_AUDIENCE=

# ── Google OAuth (Calendar) ─────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/calendar/callback

# ── Gemini AI ───────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GEMINI_TEMPERATURE=0.2

# ── WhatsApp (Meta Cloud API) ──────────────────────────────
PHONE_ID=
WHATSAPP_TOKEN=
VERIFY_TOKEN=my-verify-token
WHATSAPP_API_VERSION=v17.0

# ── PII Encryption ─────────────────────────────────────────
# 32-byte key, base64 or hex encoded
PII_ENC_KEY=
PII_KEY_ID=v1
